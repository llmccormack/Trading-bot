# Copy this to .env and fill in your values

# Claude API
ANTHROPIC_API_KEY=your_anthropic_key_here

# Market data (Polygon.io — free tier works for historical)
POLYGON_API_KEY=your_polygon_key_here

# Interactive Brokers (for live/paper trading)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497 = paper trading, 7496 = live
IBKR_CLIENT_ID=1

# Trading mode: "paper" or "live" — ALWAYS start with paper
TRADING_MODE=paper

# Risk settings
MAX_RISK_PER_TRADE_PCT=1.0      # % of account to risk per trade
MAX_DAILY_LOSS_PCT=3.0          # halt trading if daily loss exceeds this
MAX_CONCURRENT_POSITIONS=3

# Account size (used for paper trading P&L)
PAPER_ACCOUNT_SIZE=100000

# Database
DB_PATH=./trading_bot.duckdb
